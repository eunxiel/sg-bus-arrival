# Copy this file to .env.local and fill in your own LTA DataMall API key.
# Register for a free key at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
#
# IMPORTANT: never commit .env.local or paste your real key into chat, docs, or
# public repos. Rotate immediately if a key is ever exposed.

LTA_ACCOUNT_KEY=your_lta_datamall_account_key_here
